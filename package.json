{
  "name": "@amadeni/convex-e2e",
  "version": "0.1.0",
  "description": "Reusable, config-driven end-to-end test runner for Convex + Next.js projects",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "convex-e2e": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "scripts",
    "convex-helpers",
    "config.example.ts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "convex",
    "e2e",
    "testing",
    "test-runner"
  ],
  "author": "Amadeni <nicolai.hallberg@amadeni.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amadeni/convex-e2e.git"
  },
  "peerDependencies": {
    "convex": ">=1.0.0"
  },
  "dependencies": {
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "convex": "^1.32.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "pnpm@10.7.0+sha512.6b865ad4b62a1d9842b61d674a393903b871d9244954f652b8842c2b553c72176b278f64c463e52d40fff8aba385c235c8c9ecf5cc7de4fd78b8bb6d49633ab6"
}
